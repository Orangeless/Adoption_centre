<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/8"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.UserListController"
      spacing="20" alignment="TOP_CENTER"
      prefWidth="400" prefHeight="500"
      stylesheets="@style.css"
      styleClass="root">

  <ImageView fx:id="banner"
             fitHeight="150" preserveRatio="true"
             styleClass="banner"/>
  <Label text="User List"
         styleClass="title"/>

  <ListView fx:id="userListView" VBox.vgrow="ALWAYS"/>

  <HBox spacing="30" alignment="CENTER" styleClass="footer">
    <Button text="Close" onAction="#onClose" prefWidth="100"/>
  </HBox>
</VBox>
